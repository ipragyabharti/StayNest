<!-- edit wala form banao.. koi listing mae click karenge to edit waala option aayega to usme jane ke baad wla form -->

<!-- edit form mae bhi humlog ko image upload karna padega to ussme bhi uolad karne ka code likho -->
<% layout("/layouts/boilerplate") %>

    <div class="row mt-3">
      <div class="col-8 offset-2">

    <h3>Edit the Listing</h3>
    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation"
      enctype="multipart/form-data">

      <div class="mb-3">
    <label for="title" class="form-label">Title</label>
    <input name="listing[title]"  value="<%= listing.title %>" type="text" class="form-control" required >
    <div class="valid-feedback">Title looks good!</div>
      </div>
    <!-- value="<%= listing.title %>" isse purana jo listing hai ussme title pass kar do -->
    

   <div class="mb-3">
    <label for="description" class="form-label">Description</label>
    <textarea name="listing[description]" class="form-control" required><%= listing.description %></textarea>
    <div class="invalid-feedback">Please enter a short description</div>
   </div>
    

   <!-- yahan pe humlog preview ke liye image daal rahe hain -->
   <div class="mb-3">
  <label class="form-label">Current Images</label><br>
  <% listing.images.forEach(img => { %>
    <img src="<%= img.url.replace('/upload', '/upload/h_150,w_150') %>" 
         style="width:150px; height:100px; object-fit:cover; margin:4px; border-radius:8px">
  <% }) %>
  </div>
    
    

<!-- ✅ Replace with this -->
<div class="mb-3">
  <label for="image" class="form-label">Add More Images</label>
  <input 
    name="listing[images]" 
    type="file" 
    class="form-control" 
    multiple 
    accept="image/*"
  >
  <small class="text-muted">Hold Ctrl / Cmd to select multiple photos. New images will be added to existing ones.</small>
</div>
    
    <div class="row">
    <div class="mb-3 col-md-4">
     <label for="price" class="form-label">Price</label>
    <input name="listing[price]" value="<%= listing.price %>" type="number" class="form-control" required>
    <div class="invalid-feedback">Please valid price</div>
    </div>
    

    <div class="mb-3 col-md-8">
     <label for="country" class="form-label">Country</label>
    <input name="listing[country]" value="<%= listing.country %>" type="text" class="form-control" required>
    <div class="invalid-feedback">Please enter valid country</div>
    </div>
    </div>
    

    <div class="mb-3"></div>
     <label for="location" class="form-label">Location</label>
    <input name="listing[location]" value="<%= listing.location %>" type="text" class="form-control" required> 
    <div class="invalid-feedback">Please enter valid country</div>
    </div>
     
    <br><br>
    <br><br>
    <button class="btn btn-dark edit-btn mt-3 mb-3">Edit</button>
    </div>
    <br><br>
   </form>

 
</div>
</div>


