<!-- agar kabhi error bhi aaye to acche format mae aaye uska ui accha ho -->

<% layout("/layouts/boilerplate") %>
<div class="row  mt-3">
    <div class="alert alert-danger col-6 offset-3" role="alert">
    <h4 class="alert-heading"> <%= err.message %> </h4>
    <!-- pura message print ho ajyega -->
    <p><%= err.trace %></p>
</div>
</div>
