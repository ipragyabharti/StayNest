<!-- naya koi listing aad karne ke liye ye form hain -->
<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-8 offset-2">
   <br>
   <br>
        <!-- to increase or decrease the size of input fields fir make row div then col div and then occupy only 8 size out of 12 -->
         <!-- offset-2 means left side se 2 ka margin or gap -->
        <h3>Create a New Listing</h3>
        <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

        <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input name="listing[title]" placeholder="Enter a cachy title" type="text" class="form-control" required>
        <div class="valid-feedback">Title looks good!</div>
        <!-- valid message print hoga ki title sahi hain -->
        </div>

        <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea name="listing[description]" class="form-control" required></textarea>
        </div>

    <!-- <div class="mb-3">
    <label for="image"  class="form-label">Image Link</label>
    <input name="listing[image][url]" placeholder="Enter image URL" type="text" class="form-control">
    </div> -->

    <div class="mb-3">
    <label for="image"  class="form-label">Upload Listing Image </label>
    <label class="form-label">Upload Images (select multiple)</label>
<input 
  name="listing[images]" 
  type="file" 
  class="form-control" 
  multiple 
  accept="image/*"
  required
>
<small class="text-muted">Hold Ctrl / Cmd to select multiple photos</small>
    
    </div>
    

    <div class="row">
        <!-- to make price and country in one line -->
    <div class="mb-3 col-md-4">
        <label for="price"  class="form-label">Price</label>
      <input name="listing[price]" placeholder="1200" type="number" class="form-control" required>  
       
    </div>

    <div class="mb-3 col-md-8">
        <label for="country"  class="form-label">Country</label>
        <input name="listing[country]" placeholder="India" type="text" class="form-control" required>
        <div class="invalid-feedback">Country name should be valid</div>
    </div>
        </div>


    <div class="mb-3">
        <label for="location"  class="form-label">Location</label>
       <input name="listing[location]" placeholder="Jaipur, Rajasthan" type="text" class="form-control" required>
       <div class="invalid-feedback">Location should be correct</div>
       <!-- error message print hoga ki location sahi hona chahiye -->
    </div>

    <button class="btn btn-dark add-btn mt-3 px-3">Add</button>
    </form>
    </div>
</div>
