<style>
  .btn-search{
    background-color: #fe424d;
    color: white;
    border-radius: 30px;
    padding: 0 1rem 0 1rem;
  }
  .btn-search:hover{
    background-color: #fe424d;
    color: white;
  }

  .btn-search{
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-search i {
    display: inline;
    margin-right: 0.5rem;
    font-size: 0.8rem;
  }

  .search-inp{
    border-radius: 25px;
    padding: 0.5rem 3rem 0.5rem 3rem;
  }
</style>

<!-- navbar ka code copy kiye humlog bootsstrap se -->

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <!--  navbar-expand-lg matlb large screen size mae large dikhega nahi to three dots dikhai dega -->
    <!-- md medium mae bhi expanded -->
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
    <!-- compass wla icon paste ho raha hain aur wo hime ke taraf redirect karega -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <div class="navbar-nav ms-auto">
        <form class="d-flex" role="search">
          <input type="search" class="form-control me-2 search-inp" placeholder="Search destinations" >
          <button class="btn btn-search" type="submit"> <i class="fa-solid fa-magnifying-glass"></i> Search</button>
        </form>

      </div>

      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/listings/new">Add new listings</a>

        <% if(!currUser) { %>
        <a class="nav-link" href="/signup"><b>Sign Up</b></a>
        <a class="nav-link" href="/login"><b>Log In</b></a>
        <% } %>
        
        <% if(currUser) { %>
        <a class="nav-link" href="/logout"><b>Log Out</b></a>
        <% } %>
      </div>
    </div>
  </div>
</nav>